---
import { Section, GradientText } from 'astro-boilerplate-components';
import Base from '@/templates/Base.astro';
import { AppConfig } from '@/utils/AppConfig';

const title = `Message Sent - ${AppConfig.site_name}`;
const description = 'Thank you for reaching out.';
---

<Base head={{ title, description }}>
  <Section>
    <div class="mx-auto flex flex-col items-center justify-center py-24 text-center">
      
      {/* Glowing Checkmark Icon */}
      <div class="mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-cyan-900/20 border border-cyan-500/30 text-cyan-400 shadow-[0_0_30px_rgba(34,211,238,0.15)]">
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          class="h-12 w-12"
          fill="none" 
          viewBox="0 0 24 24" 
          stroke="currentColor" 
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      
      <h1 class="mb-6 text-4xl font-bold text-white sm:text-5xl tracking-tight">
        Message <GradientText>Received</GradientText>
      </h1>
      
      <p class="mb-10 max-w-lg text-lg text-gray-400 leading-relaxed font-light">
        Thank you for reaching out! I've received your message and will get back to you as soon as possible. In the meantime, feel free to check out some of my recent work.
      </p>
      
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-lg bg-cyan-500 px-8 py-3 text-lg font-bold text-slate-900 transition-all duration-300 hover:bg-cyan-400 hover:-translate-y-1 hover:shadow-[0_10px_20px_rgba(34,211,238,0.3)]"
      >
        Back to Homepage
      </a>
      
    </div>
  </Section>
</Base>